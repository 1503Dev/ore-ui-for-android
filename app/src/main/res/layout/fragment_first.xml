<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FirstFragment">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">


        <dev1503.oreui.widgets.OreButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="前往JavaDemoActivity"
            android:id="@+id/btnJavaDemo"/>
        <dev1503.oreui.widgets.OreButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Github"
            android:id="@+id/btnGithub"/>

        <LinearLayout
            android:id="@+id/button_first"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <dev1503.oreui.widgets.OreButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="白色 White"
                android:id="@+id/btnWhite"/>
            <dev1503.oreui.widgets.OreButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="紫色 Purple"
                android:id="@+id/btnPurple"/>
            <dev1503.oreui.widgets.OreButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="绿色 Green"
                android:id="@+id/btnGreen"/>
            <dev1503.oreui.widgets.OreButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="红色 Red"
                android:id="@+id/btnRed"/>
        </LinearLayout>
        <dev1503.oreui.widgets.OreButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="创建新世界"
            android:id="@+id/btnCreateWorlds"/>
        <dev1503.oreui.widgets.OreButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="取消"
            android:id="@+id/btnDarkGray"/>
        <dev1503.oreui.widgets.OreAlert
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="这是一条黄色警告"
            android:id="@+id/alertYellow"/>
        <dev1503.oreui.widgets.OreAlert
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="实验性游戏内容是潜在的新功能。可能会发生错误，请小心。"
            android:id="@+id/alertBlue"/>
        <dev1503.oreui.widgets.OreAlert
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/alertCustom"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <dev1503.oreui.widgets.OreSwitch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/switch1"/>
            <dev1503.oreui.widgets.OreSwitch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:id="@+id/switch2"/>
            <dev1503.oreui.widgets.OreSwitch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/switch3"/>
            <dev1503.oreui.widgets.OreSwitch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/switch4"/>
        </LinearLayout>
        <dev1503.oreui.widgets.OreSlider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/slider1"/>
        <dev1503.oreui.widgets.OreSlider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="5"
            android:id="@+id/slider2"/>
        <dev1503.oreui.widgets.OreEditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/editText1"/>
        <dev1503.oreui.widgets.OreEditText
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AaBbCbDdEeFfGgHhIiJjKkLlMmNnOoPpQqRrSsTtUuVvWwXxYyZz0123456789中国制造，惠及全球"
            android:id="@+id/editText2"/>
        <dev1503.oreui.widgets.OreTabs
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/tabs1"/>
        <dev1503.oreui.widgets.OreTabs
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/tabs2"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>